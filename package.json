{
  "name": "stonker",
  "version": "1.0.0",
  "description": "Real-time stock ticker PWA with trend summaries",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.build.json",
    "start": "node dist-server/server/index.js",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "cap:sync": "npx cap sync android",
    "cap:build": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug && cp app/build/outputs/apk/debug/app-debug.apk ../stonker-debug.apk"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:24929/git/dlogsr/stonker"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "undici": "^7.22.0",
    "yahoo-finance2": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
